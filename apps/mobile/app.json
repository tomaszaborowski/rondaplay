{
  "expo": {
    "name": "RondaPlay",
    "slug": "rondaplay",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2c0247"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rondaplay.app",
      "infoPlist": {
        "NSMotionUsageDescription": "RondaPlay requiere acceso a los sensores de movimiento para detectar la inclinación del teléfono al jugar a ¿Quién Soy?.",
        "NSCameraUsageDescription": "RondaPlay requiere acceso a la cámara para escanear códigos QR de salas de juego."
      }
    },
    "android": {
      "package": "com.rondaplay.app",
      "adaptiveIcon": {
        "backgroundColor": "#2c0247",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCELEROMETER",
        "GYROSCOPE",
        "VIBRATE"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
