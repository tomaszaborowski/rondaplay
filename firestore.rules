rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile document: only the authenticated owner can read/write
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Game configurations: anyone can read, only admin can write
    match /games/{gameId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Public custom pages (CMS): anyone can read, only admin can write
    match /pages/{pageId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Transactions: only the authenticated owner can read their own, no client writes allowed
    match /transactions/{txId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow write: if false;
    }
  }
}
