rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile documents: public read for leaderboards and @username lookup; owner write
    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Username reservation registry: public read to check availability; auth write
    match /usernames/{username} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
    
    // Game lobbies (El Impostor, Speed Match): open for pass & play / online multiplayer
    match /imposter_lobbies/{lobbyId} {
      allow read, write: if true;
    }

    // Game configurations: public read, admin write
    match /games/{gameId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Public custom pages (CMS): public read, admin write
    match /pages/{pageId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Transactions: authenticated owner read
    match /transactions/{txId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow write: if false;
    }
  }
}
